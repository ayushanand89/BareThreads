# PayPal client ID (from the PayPal developer dashboard)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# Backend API base URL (must include the /api suffix)
VITE_BACKEND_URL=http://localhost:9000/api

# Google OAuth Web Client ID (must match GOOGLE_CLIENT_ID on the backend)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
